{
  "name": "creem-datafast-monorepo",
  "private": true,
  "packageManager": "pnpm@10.30.0",
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm --filter @itzsudhan/creem-datafast test",
    "coverage": "pnpm --filter @itzsudhan/creem-datafast test -- --coverage",
    "pretypecheck": "pnpm --filter @itzsudhan/creem-datafast build",
    "typecheck": "pnpm -r typecheck",
    "ci": "pnpm typecheck && pnpm coverage && pnpm build",
    "smoke:webhook": "pnpm --filter @itzsudhan/creem-datafast smoke:webhook",
    "dev:demo": "pnpm --filter demo-next dev",
    "dev:express": "pnpm --filter example-express dev"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.0",
    "@types/node": "^22.15.18",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^3.2.4",
    "jsdom": "^26.1.0",
    "tsup": "^8.5.0",
    "tsx": "^4.20.6",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
