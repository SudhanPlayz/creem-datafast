{
  "name": "@itzsudhan/creem-datafast",
  "version": "0.1.0",
  "description": "Generic-first revenue attribution bridge between Creem and DataFast.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "creem-datafast": "./bin/creem-datafast.cjs"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.js",
      "require": "./dist/react/index.cjs"
    },
    "./next": {
      "types": "./dist/next.d.ts",
      "import": "./dist/next.js",
      "require": "./dist/next.cjs"
    },
    "./express": {
      "types": "./dist/express.d.ts",
      "import": "./dist/express.js",
      "require": "./dist/express.cjs"
    },
    "./client": {
      "types": "./dist/client/index.d.ts",
      "import": "./dist/client/index.js",
      "require": "./dist/client/index.cjs"
    },
    "./idempotency/upstash": {
      "types": "./dist/idempotency/upstash.d.ts",
      "import": "./dist/idempotency/upstash.js",
      "require": "./dist/idempotency/upstash.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "bin",
    "dist",
    "fixtures",
    "README.md",
    "SKILL.md"
  ],
  "scripts": {
    "build": "tsup && node ./scripts/postbuild-react-entry.cjs",
    "dev": "tsup --watch",
    "smoke:webhook": "node ./bin/creem-datafast.cjs smoke-webhook",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "creem": "^1.4.3",
    "datafast": "^2.1.2"
  },
  "peerDependencies": {
    "react": "^18.3.0 || ^19.0.0",
    "react-dom": "^18.3.0 || ^19.0.0"
  }
}
